<mxfile host="app.diagrams.net">
  <diagram name="Coding Platform HLD">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Design: Coding Platform (LeetCode)" style="text;html=1;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="300" height="40" as="geometry"/>
        </mxCell>

        <!-- Users -->
        <mxCell id="user" value="Users" style="shape=ellipse;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="100" height="60" as="geometry"/>
        </mxCell>

        <!-- API Gateway -->
        <mxCell id="gateway" value="API Gateway&#xa;- Auth&#xa;- Routing&#xa;- Rate Limit" style="rounded=1;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="200" y="180" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- Services -->
        <mxCell id="userService" value="User Service" style="rounded=1;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="450" y="80" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="problemService" value="Problem Service" style="rounded=1;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="450" y="160" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="submissionService" value="Submission Service" style="rounded=1;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="450" y="240" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="executionService" value="Code Execution Service&#xa;(Sandbox + Compiler)" style="rounded=1;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="650" y="240" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Queue -->
        <mxCell id="queue" value="Queue (Async Jobs)" style="shape=cylinder;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="650" y="150" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- Databases -->
        <mxCell id="userDB" value="User DB" style="shape=cylinder;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="900" y="80" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="problemDB" value="Problem DB" style="shape=cylinder;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="900" y="160" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="submissionDB" value="Submission DB" style="shape=cylinder;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="900" y="240" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e1" source="user" target="gateway" edge="1"/>
        <mxCell id="e2" source="gateway" target="userService" edge="1"/>
        <mxCell id="e3" source="gateway" target="problemService" edge="1"/>
        <mxCell id="e4" source="gateway" target="submissionService" edge="1"/>
        <mxCell id="e5" source="submissionService" target="queue" edge="1"/>
        <mxCell id="e6" source="queue" target="executionService" edge="1"/>

        <mxCell id="e7" source="userService" target="userDB" edge="1"/>
        <mxCell id="e8" source="problemService" target="problemDB" edge="1"/>
        <mxCell id="e9" source="submissionService" target="submissionDB" edge="1"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>