<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.1 Chrome/142.0.7444.265 Electron/39.8.0 Safari/537.36" version="29.6.1">
  <diagram name="Page-1" id="chxPgdshVmlEhFVtTOSE">
    <mxGraphModel dx="2239" dy="963" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="EI6_OOFlvVmJS4gI-N-t-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Design an e-commerce system with following requirements:&lt;br&gt;&lt;br&gt;&lt;br&gt;1.User login service&lt;br&gt;2.Search service&lt;br&gt;3.Product catalog service&lt;br&gt;4.Cart service&lt;br&gt;5.Order status service&lt;br&gt;6.Check out service&lt;br&gt;&lt;br&gt;&lt;br&gt;Optimize the product searching and inventory stock management in real time." vertex="1">
          <mxGeometry height="190" width="540" x="20" y="80" as="geometry" />
        </mxCell>
        <mxCell id="EI6_OOFlvVmJS4gI-N-t-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Functional Requirements:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;1.User should be able to login and register.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;2.User should be able to search the products and see the desciption.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;3.User will be able to see the information about the product by clicking on product.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;4. User should be able to add the products in the cart.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;5.Order status should be updated after processing the order.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="450" y="290" as="geometry" />
        </mxCell>
        <mxCell id="EI6_OOFlvVmJS4gI-N-t-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Non- functional requirements:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;1. 1.5 M Daily active users with 10 orders processed per second.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;2. Latency ~ 200ms&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;3. Scalability: Horizotal/Vertical&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;4. Consistency VS Availability: In this system , we need both,&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;Availability because the products should be available on searching.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; Consistency in two modules: Payment System and Order placing.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Inventory management.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="390" x="-5" y="430" as="geometry" />
        </mxCell>
        <mxCell id="EI6_OOFlvVmJS4gI-N-t-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;API Endpoints:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;1. User Service:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;POST: api/register/user--post the user into the database.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;POST: api/login/user-- verify the username and password.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;2. Search Service:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET: api/product?search_item=&quot;keywords&quot; -- to search the item from keywords.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;3. Product catalog service:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET: api/product/product_id -- to get the product description from product id.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;4. Cart Service:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;POST: api/cart --&amp;nbsp; add the produt into the cart.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;DELETE: api/cart/product_id -- to delete the product from the cart.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;PUT: api/cart/product_id --&amp;nbsp; to update any product in the cart.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;5.Order Status:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET: api/order/order_id -- to get the order status from db and update it on the frontend.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;6. Payment service:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET: api/payment/payment_id --&amp;nbsp; to get the status of the payment from backend and update it on the frontend.&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="350" width="490" x="10" y="600" as="geometry" />
        </mxCell>
